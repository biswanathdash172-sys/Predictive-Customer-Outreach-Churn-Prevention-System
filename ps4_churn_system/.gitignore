# ╔══════════════════════════════════════════════════════════╗
# ║  PS4 — .gitignore                                       ║
# ║  These files must NEVER be committed to Git             ║
# ╚══════════════════════════════════════════════════════════╝

# ── SECRET FILES — NEVER COMMIT THESE ────────────────────────────────────────
.env
*.pem
*.key
*.p12
*.pfx
secrets.json
credentials.json

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
.env.local

# ── ML model files (large binary — use git-lfs or model registry) ────────────
ml/*.pkl
ml/*.joblib
ml/*.model
data/customers.csv

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Test artifacts ────────────────────────────────────────────────────────────
.pytest_cache/
htmlcov/
.coverage
