# ╔══════════════════════════════════════════════════════════════════╗
# ║         PS4 — Environment Configuration Template               ║
# ║  Copy this file to .env and fill in your real values           ║
# ║  NEVER commit the .env file to Git                             ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── AI / LLM ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Application Security ──────────────────────────────────────────────────────
# Secret key for signing tokens — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_to_a_random_64_character_hex_string

# Admin API key for protected management endpoints
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=change_this_to_a_strong_random_admin_key

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AI_PER_MINUTE=10

# ── CORS — allowed frontend origins (comma-separated) ────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ── Audit Logging ─────────────────────────────────────────────────────────────
AUDIT_LOG_FILE=logs/audit.log
LOG_LEVEL=INFO
